# HyperClaude instructor workshop environment.
# Copy this file to demo/.env before the live session:
#   cp workshop/.env.example demo/.env
#
# Only change the Claude Managed Agents values when starting from a clean Claude
# Managed Agents project. Non-Claude execution credentials are host-managed.

# Claude Managed Agents
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_API_KEY
WORKSHOP_ANTHROPIC_API_KEY=CHANGE_ME_WORKSHOP_ANTHROPIC_API_KEY
ANTHROPIC_WORKSPACE_ID=
WORKSHOP_ANTHROPIC_WORKSPACE_ID=wrkspc_01Ja4EK3nFQXQqKUgf8dcLu7
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Leave these blank for a clean Managed Agents project so the demo can bootstrap
# or discover the required resources. Fill them only if you want to pin existing
# resources from a previous rehearsal.
ANTHROPIC_AGENT_ID=
ANTHROPIC_ENVIRONMENT_ID=
ANTHROPIC_CHAT_MODEL=
ANTHROPIC_CHAT_AUTO_BOOTSTRAP=true
ANTHROPIC_CHAT_MAX_OUTCOME_ITERATIONS=5
ANTHROPIC_CHAT_VAULT_IDS=
ANTHROPIC_CHAT_MCP_SERVERS=
ANTHROPIC_CHAT_ENABLE_DREAMS=false

# Optional market intelligence integrations.
# Leave blank for the fastest instructor path.
HYPERTRACKER_API_KEY=
HYPERTRACKER_BASE_URL=https://ht-api.coinmarketman.com
HYPERTRACKER_MCP_SERVER_URL=
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai/v1
PERPLEXITY_MCP_SERVER_URL=
PERPLEXITY_MODEL=perplexity/sonar

# Optional browser wallet login and Privy execution.
# Public browser values can be set for login demos. Keep PRIVY_APP_SECRET
# server-side only.
PRIVY_APP_ID=
PRIVY_CLIENT_ID=
PRIVY_APP_SECRET=
PRIVY_EXECUTION_ENABLED=false

# Hyperliquid prodnet workshop mode.
# These are not participant-editable API keys. The instructor preconfigures
# them only when the live workshop will demonstrate guarded execution.
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_API_WALLET_PRIVATE_KEY=
HYPERLIQUID_MAX_ORDER_USDC=25
HYPERLIQUID_ALLOWED_ASSETS=BTC,ETH,SOL,HYPE
WORKSHOP_HYPERLIQUID_ALLOWED_ASSETS=xyz:CL,xyz:BRENTOIL,xyz:GOLD,xyz:SILVER,xyz:SP500,flx:USA100,xyz:COPPER,vntl:WHEAT,xyz:NATGAS,BTC
HYPERLIQUID_MAINNET_ENABLED=true

# Demo guardrails
DEMO_TRADING_MODE=mainnet_guarded
DEMO_REQUIRE_CONFIRMATION=true
DEMO_STATE_DIR=.demo_state
