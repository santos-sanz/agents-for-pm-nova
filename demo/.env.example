# Claude Managed Agents
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Optional: pin the one-shot research agent resources. If omitted, the demo reuses
# local state or the newest matching Claude Managed Agents resources by name.
ANTHROPIC_AGENT_ID=
ANTHROPIC_ENVIRONMENT_ID=
ANTHROPIC_CHAT_MODEL=
ANTHROPIC_CHAT_AUTO_BOOTSTRAP=true
ANTHROPIC_CHAT_MAX_OUTCOME_ITERATIONS=5
ANTHROPIC_CHAT_VAULT_IDS=
ANTHROPIC_CHAT_MCP_SERVERS=
ANTHROPIC_CHAT_ENABLE_DREAMS=false

# HyperTracker / CoinMarketMan market intelligence
HYPERTRACKER_API_KEY=
HYPERTRACKER_BASE_URL=https://ht-api.coinmarketman.com
HYPERTRACKER_MCP_SERVER_URL=

# Perplexity Agent API finance_search enrichment
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai/v1
# Optional: HTTPS URL for a remote/tunneled Perplexity MCP HTTP server.
# The official server can run with `npx @perplexity-ai/mcp-server` or in HTTP mode
# and must be exposed over HTTPS for Claude Managed Agents, for example via MCP Tunnel.
# This demo also exposes /mcp/perplexity; point a public HTTPS tunnel at it to use
# the PERPLEXITY_API_KEY stored in Managed Agents Vault as the upstream bearer.
PERPLEXITY_MCP_SERVER_URL=
PERPLEXITY_MODEL=perplexity/sonar

# Privy browser login. These are public browser identifiers from the Privy Dashboard.
PRIVY_APP_ID=
PRIVY_CLIENT_ID=

# Privy server-side execution. Keep this secret only in backend/server environments.
PRIVY_APP_SECRET=
PRIVY_EXECUTION_ENABLED=false
PRIVY_EXTERNAL_WITHDRAWAL_ADDRESS=0xcF1D21Cd958C13aC24BA54506464E64AC80B4214

# Hyperliquid
# HYPERLIQUID_ACCOUNT_ADDRESS is your main Hyperliquid/Dreamcash wallet address.
# HYPERLIQUID_API_WALLET_PRIVATE_KEY must be an API/agent wallet private key, never
# your main wallet private key.
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_API_WALLET_PRIVATE_KEY=
HYPERLIQUID_MAX_ORDER_USDC=100
HYPERLIQUID_ALLOWED_ASSETS=BTC,ETH,SOL
HYPERLIQUID_MAINNET_ENABLED=false

# Demo guardrails
DEMO_TRADING_MODE=mainnet_guarded
DEMO_REQUIRE_CONFIRMATION=true
DEMO_STATE_DIR=.demo_state

# Cloud deployment posture
# For autonomous scheduled execution, use testnet:
# DEMO_TRADING_MODE=testnet
# HYPERLIQUID_BASE_URL=https://api.hyperliquid-testnet.xyz
# HYPERLIQUID_WS_URL=wss://api.hyperliquid-testnet.xyz/ws
# HYPERLIQUID_MAINNET_ENABLED=false
#
# Prodnet can be enabled only for guarded execution with explicit host human
# approval. Do not set DEMO_REQUIRE_CONFIRMATION=false for prodnet.
